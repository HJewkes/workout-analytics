{
  "name": "@voltras/workout-analytics",
  "version": "0.2.0",
  "description": "Hardware-agnostic workout analytics library for analyzing reps, sets, estimating RPE/RIR, calculating strength (1RM), velocity profiles, and fatigue estimates",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json && tsc-alias -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && tsc-alias -p tsconfig.cjs.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src v0",
    "lint:fix": "eslint src v0 --fix",
    "format": "prettier --write \"src/**/*.ts\" \"v0/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"v0/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "exercises:analyze": "tsx scripts/analyze/index.ts",
    "exercises:collect": "tsx scripts/collect/index.ts",
    "exercises:process": "tsx scripts/process/index.ts",
    "exercises:export": "tsx scripts/export/index.ts",
    "exercises:research": "tsx scripts/research/exercise-enrichment.ts",
    "exercises:pipeline": "npm run exercises:analyze && npm run exercises:collect && npm run exercises:process && npm run exercises:export",
    "docs:api": "typedoc --out docs/api src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typedoc": "^0.27.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.0.17"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "workout",
    "analytics",
    "fitness",
    "strength-training",
    "vbt",
    "velocity-based-training",
    "rpe",
    "rir",
    "1rm",
    "fatigue",
    "exercise"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HJewkes/workout-analytics.git"
  },
  "bugs": {
    "url": "https://github.com/HJewkes/workout-analytics/issues"
  },
  "homepage": "https://github.com/HJewkes/workout-analytics#readme",
  "author": "Voltra",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
